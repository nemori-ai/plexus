# Dependencies
node_modules/

# Build output
dist/

# Coverage output (bun test --coverage / bun run coverage)
coverage/

# Bun
.bun/
bun.lockb

# Logs
*.log

# OS
.DS_Store

# Local gateway state (created at runtime under ~/.plexus, but ignore any stray local copy)
.plexus/

# Editor
*.swp

# NOTE: .claude/ is intentionally NOT ignored (project Claude config may live here).
# But the cc-master orchestration board is session/build metadata, not product:
.claude/cc-master/
# Linked git worktrees created for isolated agent spikes (the branch persists; the checkout is scratch):
.claude/worktrees/

# Pneuma session/preference state
.pneuma/

# Python bytecode / venvs (examples/ demo agent)
__pycache__/
*.pyc
.venv/
.pytest_cache/
# DeepAgent runtime working dir (FilesystemBackend root, recreated each run)
examples/pomodoro-demo/agent_workdir/
