{
  "name": "plexus",
  "version": "0.1.0",
  "description": "Plexus — a local capability gateway exposing an AI-native self-describe protocol so any AI agent can DISCOVER → UNDERSTAND → be GRANTED → CALL the capabilities of software on the user's machine.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "plexus": "packages/runtime/bin/plexus"
  },
  "scripts": {
    "start": "bun run packages/runtime/bin/plexus",
    "print-key": "bun run packages/runtime/bin/plexus --print-key",
    "dev": "bun run --watch packages/runtime/src/index.ts",
    "serve": "bun run packages/runtime/src/index.ts",
    "demo": "bun run examples/min-agent/run.ts",
    "build": "bun build packages/runtime/src/index.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@plexus/protocol": "workspace:*",
    "@plexus/runtime": "workspace:*",
    "@plexus/cli": "workspace:*",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.6.0"
  }
}
