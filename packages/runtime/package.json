{
  "name": "@plexus/runtime",
  "version": "0.6.0-rc.1",
  "description": "Plexus headless capability gateway (the runtime) — `plexus serve` entrypoint, listen-adapter seam, GatewayState, auth/grant/invoke pipeline, sources + platform seam.",
  "type": "module",
  "private": true,
  "bin": {
    "plexus": "bin/plexus"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build:compile": "bun run scripts/build-compile.ts",
    "build:compile:arm64": "bun run scripts/build-compile.ts -- --target=bun-darwin-arm64",
    "build:compile:x64": "bun run scripts/build-compile.ts -- --target=bun-darwin-x64"
  },
  "dependencies": {
    "@plexus/protocol": "workspace:*",
    "hono": "^4.7.0"
  }
}
