# Keep the appliance build context lean + force a FRESH Linux dependency install.
# (Paths are relative to the build context = repo root, since builds use
#  `docker build -f docker/Dockerfile.appliance -t plexus-appliance:latest .`)
node_modules
**/node_modules
dist
**/dist
coverage
.git
.bun
*.log
.DS_Store
.plexus
.pneuma
__pycache__
.venv
examples/pomodoro-demo/agent_workdir
.claude/cc-master
.claude/worktrees
# Demo runtime artifacts — generated by run scripts, never baked in.
docker/certs
docker/*.env
docker/.env
# The appliance's own example exposed-data is operator-supplied at run time via a mount,
# never baked into the image.
examples/appliance/exposed-data
