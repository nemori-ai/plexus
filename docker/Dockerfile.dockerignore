# Keep the build context lean and force a FRESH Linux dependency install.
# (Paths are relative to the build context = repo root, since builds use `-f docker/Dockerfile ..`.)
node_modules
**/node_modules
dist
**/dist
coverage
.git
.bun
*.log
.DS_Store
.plexus
.pneuma
__pycache__
.venv
examples/pomodoro-demo/agent_workdir
.claude/cc-master
.claude/worktrees
# Demo runtime artifacts — generated by run-multihost-docker.sh, never baked in.
docker/certs
docker/*.env
docker/.env
