{
  "compilerOptions": {
    // ── Bun + ESM target ────────────────────────────────────────────────────
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    // ── Workspace package aliases (the keystone protocol pkg) ────────────────
    // `@plexus/protocol` is resolved by Bun via workspaces at runtime; tsc needs
    // this path mapping so `bunx tsc --noEmit` resolves it from source.
    "baseUrl": ".",
    "paths": {
      "@plexus/protocol": ["packages/protocol/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["bun"],

    // ── Strictness — the same bar the frozen contract types.ts already passes ─
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  },
  "include": ["src", "tests", "packages/protocol/src", "docs/protocol/types.ts"],
  "exclude": ["node_modules", "dist", "management-client"]
}
