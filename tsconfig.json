{
  "compilerOptions": {
    // ── Bun + ESM target ────────────────────────────────────────────────────
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    // ── Workspace package aliases ────────────────────────────────────────────
    // These packages are resolved by Bun via workspaces at runtime; tsc needs the
    // matching path mappings so `bunx tsc --noEmit` resolves them from source.
    //   @plexus/protocol  — the shared keystone contract.
    //   @plexus/runtime/* — deep imports into the runtime package (was `src/*`).
    "baseUrl": ".",
    "paths": {
      "@plexus/protocol": ["packages/protocol/src/index.ts"],
      "@plexus/runtime": ["packages/runtime/src/index.ts"],
      "@plexus/runtime/*": ["packages/runtime/src/*"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["bun"],

    // ── Strictness — the same bar the frozen contract types.ts already passes ─
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  },
  // Gate scope mirrors the pre-monorepo baseline (runtime src/bin + tests +
  // protocol + the docs mirror). examples/ and plugins/ are pulled in transitively
  // via the tests that import them, exactly as before the carve. packages/cli/src
  // is added because the carve rewired it and it must stay compiler-validated.
  "include": [
    "packages/protocol/src",
    "packages/runtime/src",
    "packages/runtime/bin",
    "packages/cli/src",
    "tests",
    "docs/protocol/types.ts"
  ],
  "exclude": ["node_modules", "dist", "packages/web-admin"]
}
